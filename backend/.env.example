# Kopiere diese Datei als .env und trage deine API-Keys ein
DATABASE_URL=sqlite:///./polyglot.db

# Optional: KI-Features (App funktioniert auch ohne Keys)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=   # Erforderlich für hochwertige TTS (OpenAI nova-Stimme) und KI-Funktionen
MISTRAL_API_KEY=  # Für KI-Satzgenerierung via Mistral

# CORS
FRONTEND_URL=http://localhost:3000
